---
import Layout from '../layouts/Layout.astro';
---

<Layout>

    <main class="container-general">
        <h1>LISTA DE SERVICIOS</h1>  
        <table id="lista-servicios"></table>
        
        <div class="container-boton_agregar">
            <a href="/servicios/agregar-servicios" class="boton-agregar">Agregar Servicio</a>
        </div>
    </main>

    <script type="module">

        document.addEventListener('DOMContentLoaded', async () => {
            try {
                
                const response = await fetch('/api/servicios');
                const servicios = await response.json();
    
                const tabla = document.getElementById('lista-servicios');
                tabla.innerHTML = ''; 

                // Si no hay registros, mostrar mensaje de error
                if (servicios.mensaje) { 
                    tabla.innerHTML = `
                        <tbody>
                            <tr>
                                <td colspan="4" style="color: red; text-align: center;">${servicios.mensaje}</td>
                            </tr>
                        </tbody>
                    `;
                    return;
                }

                const thead = document.createElement('thead');
                thead.innerHTML = `
                    <tr>
                        <th>Servicio</th>
                        <th>% Spa</th>
                        <th>% Empleado</th>
                        <th>Acciones</th>
                    </tr>
                `;
                tabla.appendChild(thead);

                const tbody = document.createElement('tbody');
    
                // Crear elementos HTML
                servicios.forEach(servicio => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td>${servicio.nombre.toUpperCase()}</td>
                        <td>${servicio.porcentaje_spabella}%</td>
                        <td>${servicio.porcentaje_empleado}%</td>
                        <td><button type="button" class="boton-eliminar">Eliminar</button></td>
                    `;

                    const btnEliminar = tr.querySelector('.boton-eliminar');

                    btnEliminar.addEventListener('click', async () => {
                        try {
                            const deleteResponse = await fetch('/api/servicios/delete', {
                                method: 'DELETE',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ id: servicio.id })
                            });

                            const result = await deleteResponse.json();

                            if (!deleteResponse.ok) {
                                alert(result.error || 'No se pudo eliminar el servicio.');
                                return;
                            }

                            alert(result.message);
                            tr.remove();
                        } catch (error) {
                            console.error("Error eliminando servicio:", error);
                        }
                    });

                    tbody.appendChild(tr);
                });

                tabla.appendChild(tbody);
    
            } catch (error) {
                console.error("Error obteniendo servicios:", error);
            }
        });

    </script>

</Layout>