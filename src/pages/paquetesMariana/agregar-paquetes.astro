---
import Layout from '../../layouts/Layout.astro';
---

<Layout>

    <main class="container-general">
        <h1>AGREGAR PAQUETE</h1>

        <form action="/agregar-paquetes" id="formulario">
            <label for="buscar-cliente">Buscar paciente</label>
            <input type="text" id="buscar-cliente" placeholder="Buscar paciente" autocomplete="off" />
            <br />
            <label for="cliente">Paciente</label>
            <select name="cliente" id="cliente">
                <option value="">Paciente</option>
            </select>
            <br />

            <label for="descripcion">Descripción del paquete</label>
            <input type="text" name="descripcion" id="descripcion" placeholder="Descripción del Paquete" />
            <br />

            <label for="nro-sesiones">Número de sesiones</label>
            <input type="text" name="nro-sesiones" id="nro-sesiones" placeholder="Número de sesiones" />
            <br />

            <label for="monto">Monto en dólares</label>
            <input type="text" name="monto" id="monto" placeholder="Monto en dólares" />
            <br />

            <label for="fecha">Fecha de compra</label>
            <input type="date" name="fecha" id="fecha" placeholder="Fecha de la compra" />
            <br />

            <button type="submit" style="margin-top: 40px;">Agregar</button>
        </form>
    </main>

    <style>

        input[type="date"]{
            width: 300px;
            height: 50px;
        }

        #buscar-cliente {
            width: 300px;
            height: 50px;
            border: none;
            border-bottom: 1.5px solid #4D4D4D;
            background-color: transparent;
            backdrop-filter: blur(10px);
        }

        #buscar-cliente:focus {
            outline: none;
            border-bottom: 2px solid #DDB57F;
        }

    </style>

    <script type="module">

        // Rellenar select de clientes

        const buscarClienteInput = document.getElementById("buscar-cliente");
        const clienteSelect = document.getElementById("cliente");
        let clientesCache = [];

        const renderClientes = (filtro = '') => {
            const termino = filtro.trim().toLowerCase();
            const clientesFiltrados = termino
                ? clientesCache.filter((cliente) => {
                    const textoBusqueda = `${cliente.nombre} ${cliente.celular}`.toLowerCase();
                    return textoBusqueda.includes(termino);
                })
                : clientesCache;

            clienteSelect.innerHTML = '';

            const optionDefault = document.createElement("option");
            optionDefault.value = "";
            optionDefault.textContent = clientesFiltrados.length
                ? 'Paciente'
                : 'Sin resultados';
            clienteSelect.appendChild(optionDefault);

            clientesFiltrados.forEach(cliente => {
                const option = document.createElement("option");
                option.value = cliente.id;
                option.textContent = `${cliente.nombre.toUpperCase()}`;
                clienteSelect.appendChild(option);
            });
        };

        try {
            const response = await fetch("/api/clientes/rellenar-selects-reservas");
            const data = await response.json();

            clientesCache = data.clientesEnvios || [];
            renderClientes();

        } catch (error) {
            console.error("Error al cargar clientes:", error);
        }

        buscarClienteInput.addEventListener('input', () => {
            renderClientes(buscarClienteInput.value);
        });

        const formulario = document.getElementById('formulario');

        formulario.addEventListener('submit', (event) => {

            event.preventDefault();

            const descripcion = document.getElementById("descripcion").value
            const nroSesiones = document.getElementById("nro-sesiones").value;
            const monto = document.getElementById("monto").value;
            const fecha = document.getElementById("fecha").value;
            const clienteId = document.getElementById("cliente").value;

            const montoTotal = Number(monto);
            const nroSesionesTotal = Number(nroSesiones);

            // Validar campos
            if (descripcion === '' || montoTotal === '' || fecha === '' || clienteId === '' || nroSesionesTotal === '') {
                alert('Por favor, rellena todos los campos.');
                formulario.reset();
                return;
            }
            if (!/^\d*\.?\d+$/.test(montoTotal) || !/^\d*$/.test(nroSesionesTotal)) {
                alert('El monto y el número de sesiones deben ser números.');
                formulario.reset();
                return;
            }

            console.log(montoTotal, nroSesionesTotal, descripcion, fecha, clienteId);

            // Enviar datos al servidor
            const url = "/api/paquetesMariana";
            fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ descripcion, nroSesionesTotal, montoTotal, fecha, clienteId }),
            })
            .then((response) => {
                if (!response.ok) {
                    throw new Error('Algo está mal con tu FETCH', response.status );
                } 
                return response.json();
            })
            .then((data) => {
                console.log(data);
                formulario.reset();

                if (data.paqueteId) {
                    window.location.href = `/paquetesMariana/detalles?paquete=${data.paqueteId}`;
                    return;
                }

                window.location.href = '/paquetesMariana';
            })  
        });

    </script>

    </Layout>