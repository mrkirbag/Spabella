---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
    
    <main class="container-general">
        <h1>AGREGAR RESERVA</h1>

        <form action="/agregar-ventas" id="formulario">
            <input type="date" name="fecha" id="fecha"/>
            <br />
            <input type="text" name="descripcion" id="descripcion" placeholder="Descripción del Servicio" />
            <br />
            <select name="cliente-id" id="cliente-id">
                <option value="">Selecciona un Cliente</option>
            </select>
            <br />
            <button type="submit" style="margin-top: 40px;">Agregar</button>
        </form>

    <script type="module">

        document.addEventListener("DOMContentLoaded", async () => {

            const clienteSelect = document.getElementById("cliente-id");

            try {
                const response = await fetch("/api/clientes/rellenar-selects-reservas");
                const data = await response.json();

                console.log(data.clientesEnvios);

                // Rellenar select de clientes
                data.clientesEnvios.forEach(cliente => {
                    const option = document.createElement("option");
                    option.value = cliente.id;
                    option.textContent = `${cliente.nombre.toUpperCase()} - 0${cliente.celular}`;
                    clienteSelect.appendChild(option);
                });

            } catch (error) {
                console.error("Error al cargar clientes:", error);
            }
        });

        const formulario = document.getElementById('formulario');

        formulario.addEventListener('submit', (event) => {
        
            event.preventDefault();

            const fecha = document.getElementById('fecha').value;
            const descripcion = document.getElementById('descripcion').value;
            const clienteId = document.getElementById('cliente-id').value;


            // Validar campos
            if (fecha === '' || clienteId === '' || descripcion === '') {
                alert('Por favor, rellena todos los campos.');
                formulario.reset();
                return;
            }

            // Enviar datos al servidor
            const url = "/api/reservas";
            fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ fecha, descripcion, clienteId }),
            })
            .then((response) => {
                if (!response.ok) {
                    throw new Error('Algo está mal con tu FETCH', response.status );
                } 
                return response.json();
            })
            .then((data) => {
                formulario.reset();
                window.location.href = '/reservas';
            })
        });
            

    </script>


</Layout>