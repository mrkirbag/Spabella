---
import Layout from '../layouts/Layout.astro';
---

<Layout>

    <main class="container-general">
        <h1>LISTA DE EMPLEADOS</h1>  
        <table id="lista-empleados"></table>
        
        <div class="container-boton_agregar">
            <a href="/empleados/agregar-empleados" class="boton-agregar">Agregar Empleado</a>
        </div>
    </main>

    <script type="module">

        document.addEventListener('DOMContentLoaded', async () => {
            try {

                const response = await fetch('/api/empleados'); 
                const empleados = await response.json();
    
                const tabla = document.getElementById('lista-empleados');
                tabla.innerHTML = ''; 

                // Si no hay registros, mostrar mensaje de error
                if (empleados.mensaje) { 
                    tabla.innerHTML = `
                        <tbody>
                            <tr>
                                <td colspan="3" style="color: red; text-align: center;">${empleados.mensaje}</td>
                            </tr>
                        </tbody>
                    `;
                    return;
                }

                const thead = document.createElement('thead');
                thead.innerHTML = `
                    <tr>
                        <th>Nombre</th>
                        <th>Cargo</th>
                        <th>Acciones</th>
                    </tr>
                `;
                tabla.appendChild(thead);

                const tbody = document.createElement('tbody');

                // Crear elementos HTML
                empleados.forEach(empleado => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td>${empleado.nombre.toUpperCase()}</td>
                        <td>${empleado.cargo.toUpperCase()}</td>
                        <td><button type="button" class="boton-eliminar">Eliminar</button></td>
                    `;

                    const btnEliminar = tr.querySelector('.boton-eliminar');

                    btnEliminar.addEventListener('click', async () => {
                        try {
                            const deleteResponse = await fetch('/api/empleados/delete', {
                                method: 'DELETE',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ id: empleado.id })
                            });

                            const result = await deleteResponse.json();

                            if (!deleteResponse.ok) {
                                alert(result.error || 'No se pudo eliminar el empleado.');
                                return;
                            }

                            alert(result.message);
                            tr.remove();
                        } catch (error) {
                            console.error("Error eliminando empleado:", error);
                        }
                    });

                    tbody.appendChild(tr);
                });

                tabla.appendChild(tbody);
    
            } catch (error) {
                console.error("Error obteniendo empleados:", error);
            }
        });

    </script>
    
</Layout>